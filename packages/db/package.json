{
  "name": "@restrobooth/db",
  "private": true,
  "version": "0.0.0",
  "description": "Drizzle schema, hand-written SQL migrations, RLS/override test suites, bench harness. See docs/ERD.md and docs/adr/0003-orm.md.",
  "type": "module",
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "scripts": {
    "build": "tsc -p tsconfig.build.json",
    "lint": "eslint .",
    "typecheck": "tsc --noEmit",
    "test": "vitest run",
    "db:generate": "drizzle-kit generate",
    "db:migrate": "drizzle-kit migrate",
    "db:check": "drizzle-kit check",
    "db:check-partitions": "tsx scripts/check-partitions-ahead.ts",
    "seed": "tsx scripts/seed-believable-chain.ts",
    "seed:auth": "tsx scripts/seed-auth-users.ts",
    "seed:categories": "tsx scripts/seed-categories.ts",
    "seed:kitchen-sections": "tsx scripts/seed-kitchen-sections.ts",
    "purge": "tsx scripts/purge-order-data.ts",
    "tokens:mint": "tsx scripts/mint-table-tokens.ts",
    "import:steakhouse": "tsx scripts/import-steakhouse.ts",
    "backfill:menu-tags": "tsx scripts/backfill-menu-tags.ts",
    "backfill:embeddings": "tsx scripts/backfill-embeddings.ts"
  },
  "dependencies": {
    "@huggingface/transformers": "^3.8.1",
    "drizzle-orm": "^0.45.2",
    "pg": "^8.22.0",
    "qrcode": "^1.5.4"
  },
  "devDependencies": {
    "@restrobooth/config": "workspace:*",
    "@supabase/supabase-js": "^2.110.3",
    "@types/pg": "^8.20.0",
    "@types/qrcode": "^1.5.6",
    "dotenv": "^17.4.2",
    "drizzle-kit": "^0.31.10",
    "eslint": "^9.39.5",
    "tsx": "^4.23.1",
    "typescript": "~5.9.3",
    "vitest": "^4.1.10"
  }
}
