{
  "name": "restrobooth",
  "private": true,
  "version": "0.0.0",
  "engines": {
    "node": ">=24"
  },
  "packageManager": "pnpm@11.12.0",
  "scripts": {
    "build": "turbo run build",
    "dev": "turbo run dev",
    "lint": "turbo run lint",
    "typecheck": "turbo run typecheck",
    "test": "turbo run test",
    "seed": "pnpm --filter @restrobooth/db run seed",
    "screenshot": "node tools/screenshot.mjs",
    "login:save-state": "node tools/login-and-save-state.mjs"
  },
  "devDependencies": {
    "playwright": "^1.61.1",
    "turbo": "^2.10.4",
    "typescript": "~5.9.3"
  }
}
