# apps/hub environment. Copy to .env.local (gitignored) to run.
#
# Hub has no auth or database of its own — it's a picker page, three plain
# cross-origin links. These are the only vars it reads. Local dev falls
# back to localhost:3001-3003 in code (app/page.tsx) if unset, so this file
# only matters when you want Hub to link somewhere other than the default
# local ports. A real deploy supplies its own via the platform's env
# (Vercel dashboard, Hub project → Settings → Environment Variables), never
# this file — same rule as every other app's .env.example in this repo.

NEXT_PUBLIC_POS_URL=http://localhost:3001
NEXT_PUBLIC_KDS_URL=http://localhost:3002
NEXT_PUBLIC_CAPTAIN_URL=http://localhost:3003
