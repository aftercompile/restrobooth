# apps/booth environment. Copy to .env.local (gitignored) to run.
#
# Unlike pos/kds/captain/console, the Booth has no staff login — guest
# identity is the rb_guest_session cookie (apps/booth/lib/guest-session.ts),
# not Supabase Auth. So there's no NEXT_PUBLIC_SUPABASE_* pair here, only
# the direct Postgres connection.

# Port 54322 is the Supabase-local stack's database (matches every other
# app's .env.local) — NOT the docker-compose dev instance on 54329.
DATABASE_URL=postgresql://postgres:postgres@127.0.0.1:54322/postgres
