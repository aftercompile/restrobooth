# apps/captain environment. Copy to .env.local (gitignored) to run.
#
# These are the Supabase CLI local stack's well-known demo values — they
# are the SAME for every `supabase start` and are NOT secrets. A real
# staging/production deploy supplies its own via the platform's env, never
# this file.

# Direct Postgres connection for RLS-scoped queries (packages/db). Port
# 54322 is the Supabase-local stack's database — the one GoTrue writes
# users into — NOT the docker-compose dev instance on 54329.
DATABASE_URL=postgresql://postgres:postgres@127.0.0.1:54322/postgres

# Supabase Auth (GoTrue) — the API gateway and the anon (public) key.
NEXT_PUBLIC_SUPABASE_URL=http://127.0.0.1:54321
NEXT_PUBLIC_SUPABASE_ANON_KEY=eyJhbGciOiJIUzI1NiIsInR5cCI6IkpXVCJ9.eyJpc3MiOiJzdXBhYmFzZS1kZW1vIiwicm9sZSI6ImFub24iLCJleHAiOjE5ODM4MTI5OTZ9.CRXP1A7WOeoJeXxjNni43kdQwgnWNReilDMblYTn_I0
